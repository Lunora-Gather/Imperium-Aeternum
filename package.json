{
  "name": "imperium-aeternum",
  "version": "1.0.0-preview",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "pages:build": "vite build",
    "check:bundle": "tsx scripts/check-build-size.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stability": "vitest run src/engine/__tests__/turnStability.test.ts src/store/__tests__/persistenceRoundtrip.test.ts src/store/__tests__/gameStorePipeline.test.ts src/gameplay/__tests__/dashboardStability.test.ts src/gameplay/__tests__/turnPipeline.test.ts src/gameplay/__tests__/stateInvariants.test.ts src/gameplay/__tests__/playerActions.test.ts src/gameplay/__tests__/eventQueueIntegration.test.ts",
    "test:invariants": "vitest run src/gameplay/__tests__/turnPipeline.test.ts src/gameplay/__tests__/stateInvariants.test.ts src/gameplay/__tests__/stateHygiene.test.ts",
    "simulate:stability": "tsx scripts/simulate-stability.ts",
    "simulate:benchmark": "tsx scripts/simulate-stability.ts --samples=5",
    "test:targeted": "vitest run src/gameplay/__tests__/commandExecutionPlan.test.ts src/gameplay/__tests__/actionPlanSummary.test.ts src/gameplay/__tests__/strategicHq.test.ts src/gameplay/__tests__/dashboardCommandGroups.test.ts src/gameplay/__tests__/governorAdvisor.test.ts src/gameplay/__tests__/releaseReadiness.test.ts src/gameplay/__tests__/onboardingCoach.test.ts src/gameplay/__tests__/economyAdvisor.test.ts src/gameplay/__tests__/diplomacyAdvisor.test.ts src/gameplay/__tests__/turnRiskCenter.test.ts src/gameplay/__tests__/warAssessment.test.ts src/gameplay/__tests__/warPreview.test.ts src/gameplay/__tests__/warOpportunityAdvisor.test.ts src/gameplay/__tests__/aiWarDecision.test.ts src/gameplay/__tests__/aiWarActionAdapter.test.ts src/engine/__tests__/aiWarPlannerIntegration.test.ts",
    "rc:check": "npm run typecheck && npm run validate && npm run test && npm run simulate:stability && npm run pages:build && npm run check:bundle",
    "validate": "tsx src/data/__validate__.ts",
    "export-data": "tsx scripts/export-data.ts",
    "build:shared-world-engine": "esbuild scripts/shared-world-engine-entry.ts --bundle --platform=node --format=esm --target=node22 --outfile=functions/shared-world-gateway/src/engine-bundle.js"
  },
  "dependencies": {
    "appwrite": "^26.2.0",
    "immer": "^10.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
