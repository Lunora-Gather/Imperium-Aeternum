{
  "name": "imperium-aeternum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "pages:build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stability": "vitest run src/engine/__tests__/turnStability.test.ts src/store/__tests__/persistenceRoundtrip.test.ts src/gameplay/__tests__/dashboardStability.test.ts",
    "rc:check": "npm run typecheck && npm run validate && npm run test:stability && npm run pages:build",
    "validate": "tsx src/data/__validate__.ts",
    "export-data": "tsx scripts/export-data.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
